## Reranker model
RERANKER_MODEL_NAME=Qwen/Qwen3-Reranker-8B
RERANKER_API_URL=https://api.siliconflow.cn/v1/rerank
RERANKER_API_KEY=

## Embedding model
EMBEDDING_MODEL_NAME=Qwen/Qwen3-Embedding-8B
EMBEDDING_API_URL=https://api.siliconflow.cn/v1/embeddings
EMBEDDING_API_KEY=

## General LLM model (OpenAI compatible)
MOONSHOT_MODEL_NAME=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=

LLM_MODEL_NAME=
LLM_API_URL=https://api.moonshot.cn/v1/chat/completions
LLM_API_KEY=

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./data/chromadb

# Search Configuration
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3
RRF_K=60

# Progressive Disclosure
LEVEL1_TOP_K=10
LEVEL2_TOP_K=20
LEVEL3_TOP_K=30
RELEVANCE_THRESHOLD=0.7
RERANK_THRESHOLD=0.5

# Context Window
MAX_CONTEXT_TOKENS=100000
CONVERSATION_HISTORY_TURNS=3

# Generation Routes
QUICK_ANSWER_MAX_CHUNKS=3
TUTORIAL_MAX_CHUNKS=10
DEEPDIVE_MAX_CHUNKS=20